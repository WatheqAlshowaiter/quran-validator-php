{
    "name": "watheqalshowaiter/quran-validator",
    "description": "Validate Quran quotations, references, ranges, and tagged content.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "Quran",
        "Islamic",
        "validation",
        "llm",
        "Arabic",
        "text-verification",
        "ai",
        "nlp"
    ],
    "authors": [
        {
            "name": "Watheq Alshowaiter",
            "email": "watheq.alshowaiter@gmail.com"
        },
        {
            "name": "Yazin Alirhayim"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/polyfill-intl-normalizer": "^1.38",
        "symfony/polyfill-mbstring": "^1.38"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Watheq\\QuranValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Watheq\\QuranValidator\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.1.0"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix --diff",
        "check": [
            "@test",
            "@analyse",
            "php-cs-fixer fix --dry-run --diff"
        ]
    },
    "suggest": {
        "ext-mbstring": "Provides faster native multibyte string handling.",
        "ext-intl": "Provides faster native Unicode normalization."
    }
}
